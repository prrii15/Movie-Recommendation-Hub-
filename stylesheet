body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-size: cover;
    background-position: center;
}

header {
    background-color: rgba(0, 0, 0, 0.5);
    padding: 80px;
    text-align: center;
    position: relative;
    background-position: center;
    background-attachment:fixed;
    Background-size:cover;

}

header h1 {
    color: #fff;
}

.top-right {
    position: absolute;
    top: 20px;
    right: 20px;
}

.login-btn {
    color: #fff;
    text-decoration: none;
    margin-right: 20px;
}

.settings-icon {
    color: #fff;
    cursor: pointer;
}

form {
    margin-top: 20px;
}

input[type="search"] {
    width: 50%;
    height: 40px;
    padding: 10px;
    font-size: 18px;
    border: none;
    border-radius: 5px 0 0 5px;
}

button {
    height: 40px;
    padding: 10px 20px;
    font-size: 18px;
    border: none;
    border-radius: 0 5px 5px 0;
    background-color: #4CAF50;
    color: #fff;
    cursor: pointer;
}

main {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    padding: 20px;
}
